<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Editorial Magazine Invoice</title>
</head>

<body style="
  margin:0;
  padding:40px;
  background:#f8fafc;
  font-family:Arial,sans-serif;
  color:#0f172a;
">

  <!-- Main Wrapper -->
  <div style="
    max-width:1100px;
    margin:auto;
    background:white;
    border-radius:36px;
    overflow:hidden;
    box-shadow:0 20px 60px rgba(15,23,42,0.08);
  ">

    <!-- Top Header -->
    <div style="
      padding:18px 55px;
      border-bottom:1px solid #e2e8f0;
      position:relative;
    ">

      <!-- Decorative -->
      <div style="
        position:absolute;
        width:240px;
        height:240px;
        border-radius:50%;
        background:#f1f5f9;
        top:-120px;
        right:-80px;
      "></div>

      <table width="100%">
        <tr>

          <!-- Brand -->
          <td valign="top">

            <div style="
              font-size:13px;
              letter-spacing:6px;
              color:#64748b;
              margin-bottom:10px;
            ">
              PREMIUM STORE
            </div>

            <div style="
              font-size:40px;
              font-weight:bold;
              line-height:40px;
            ">
              MONO
            </div>

            <div style="
              margin-top:13px;
              color:#64748b;
              line-height:16px;
              font-size:12px;
            ">
              Contemporary Shopping Experience <br>
              Ahmedabad, Gujarat, India
            </div>

          </td>

          <!-- Invoice -->
          <td align="right" valign="top">

            <div style="
              font-size:13px;
              letter-spacing:5px;
              color:#64748b;
              margin-bottom:18px;
              z-index:9999;
              position:relative;
            ">
              ORDER RECEIPT
            </div>

            <div style="
              font-size:27px;
              font-weight:bold;
              line-height:3px;
              position:relative;
            ">
              INVOICE
            </div>

            <div style="
              margin-top:22px;
              display:inline-block;
              padding:14px 26px;
              border-radius:50px;
              background:#0f172a;
              color:white;
              font-weight:bold;
              font-size:14px;
              letter-spacing:2px;
              position:relative;
            ">
              <%= invoice.invoiceNumber %>
            </div>

          </td>

        </tr>
      </table>

    </div>

    <!-- Main Content -->
    <div style="
      padding:18px 50px;
    ">

      <!-- Customer + Payment -->
      <table width="100%" style="margin-bottom:6px;">
        <tr>

          <!-- Customer -->
          <td width="48%" valign="top">

            <div style="
              border:1px solid #e2e8f0;
              border-radius:30px;
              padding:35px;
            ">

              <div style="
                font-size:13px;
                letter-spacing:3px;
                color:#64748b;
                margin-bottom:22px;
                font-weight:bold;
              ">
                CUSTOMER
              </div>

              <div style="
                font-size:24px;
                font-weight:bold;
                margin-bottom:16px;
              ">
                <%= invoice.customerName %>
              </div>

              <div style="
                color:#64748b;
                line-height:34px;
                font-size:15px;
              ">
                <%= invoice.city %>, India <br>
                <%= invoice.email %>
              </div>

            </div>

          </td>

          <td width="4%"></td>

          <!-- Payment -->
          <td width="48%" valign="top">

            <div style="
              border:1px solid #e2e8f0;
              border-radius:30px;
              padding:35px;
            ">

              <div style="
                font-size:13px;
                letter-spacing:3px;
                color:#64748b;
                margin-bottom:22px;
                font-weight:bold;
              ">
                PAYMENT DETAILS
              </div>

              <table width="100%">

                <tr>
                  <td style="
                    padding:14px 0;
                    color:#64748b;
                    font-size:15px;
                  ">
                    Date
                  </td>

                  <td align="right" style="
                    font-weight:bold;
                  ">
                    <%= invoice.date %>
                  </td>
                </tr>

                <tr>
                  <td style="
                    padding:14px 0;
                    color:#64748b;
                    font-size:15px;
                  ">
                    Method
                  </td>

                  <td align="right" style="
                    font-weight:bold;
                  ">
                    <%= invoice.paymentMethod %>
                  </td>
                </tr>

                <tr>
                  <td style="
                    padding:14px 0;
                    color:#64748b;
                    font-size:15px;
                  ">
                    Status
                  </td>

                  <td align="right">

                    <span style="
                      background:#dcfce7;
                      color:#166534;
                      padding:10px 20px;
                      border-radius:30px;
                      font-size:13px;
                      font-weight:bold;
                    ">
                      PAID
                    </span>

                  </td>
                </tr>

              </table>

            </div>

          </td>

        </tr>
      </table>

      <!-- Product Section -->
      <div style="
        border:1px solid #e2e8f0;
        border-radius:32px;
        overflow:hidden;
      ">

        <!-- Heading -->
        <div style="
          padding:10px 35px;
          border-bottom:1px solid #e2e8f0;
          background:#f8fafc;
        ">

          <div style="
            font-size:15px;
            font-weight:bold;
          ">
            Purchased Products
          </div>

        </div>

        <!-- Products -->
        <table width="100%" cellspacing="0" cellpadding="0">

          <% invoice.products.forEach((product,index)=> { %>

            <tr style="
              background:<%= index % 2 === 0 ? '#ffffff' : '#f8fafc' %>;
              border-bottom:1px solid #e2e8f0;
            ">

              <!-- Product -->
              <td style="
                padding:10px 35px;
              ">

                <table width="100%">
                  <tr>

                    <!-- Product Left -->
                    <td>

                      <div style="
                        display:flex;
                        align-items:center;
                        gap:22px;
                      ">

                        <div>

                          <div style="
                            font-size:15px;
                            font-weight:bold;
                          ">
                            <%= product.name %>
                          </div>
                        </div>
                      </div>

                    </td>

                    <!-- Qty -->
                    <td align="center" width="120">

                      <div style="
                        font-size:15px;
                        font-weight:bold;
                      ">
                        x<%= product.qty %>
                      </div>

                    </td>

                    <!-- Price -->
                    <td align="right" width="170">

                      <div style="
                        font-size:15px;
                        color:#64748b;
                      ">
                        ₹ <%= product.price %>
                      </div>

                    </td>

                    <!-- Total -->
                    <td align="right" width="200">

                      <div style="
                        font-size:15px;
                        font-weight:bold;
                      ">
                        ₹ <%= product.price * product.qty %>
                      </div>

                    </td>

                  </tr>
                </table>

              </td>

            </tr>

          <% }) %>

        </table>

      </div>

      <!-- Bottom -->
      <table width="100%" style="margin-top:6px;">
        <tr>

          <!-- Message -->
          <td width="54%" valign="top">

            <div style="
              background:#0f172a;
              color:white;
              border-radius:32px;
              padding:20px;
            ">

              <div style="
                font-size:34px;
                font-weight:bold;
                margin-bottom:18px;
              ">
                Thank You
              </div>

              <div style="
                color:rgba(255,255,255,0.7);
                line-height:36px;
                font-size:15px;
              ">
                We appreciate your purchase from MONO.
                Your order has been processed successfully and
                will be shipped shortly.
              </div>

            </div>

          </td>

          <td width="4%"></td>

          <!-- Total -->
          <td width="42%" valign="top">

            <div style="
              border:1px solid #e2e8f0;
              border-radius:32px;
              padding:20px;
            ">

              <div style="
                font-size:14px;
                letter-spacing:3px;
                color:#64748b;
                margin-bottom:20px;
                font-weight:bold;
              ">
                PAYMENT SUMMARY
              </div>

              <table width="100%">

                <tr>
                  <td style="
                    padding:10px 0;
                    color:#64748b;
                  ">
                    Subtotal
                  </td>

                  <td align="right" style="
                    font-weight:bold;
                  ">
                    ₹ <%= invoice.subtotal %>
                  </td>
                </tr>

                <tr>
                  <td style="
                    padding:10px 0;
                    color:#64748b;
                  ">
                    GST (18%)
                  </td>

                  <td align="right" style="
                    font-weight:bold;
                  ">
                    ₹ <%= invoice.gst %>
                  </td>
                </tr>

                <tr>
                  <td style="
                    padding:10px 0;
                    color:#64748b;
                  ">
                    Shipping
                  </td>

                  <td align="right" style="
                    font-weight:bold;
                  ">
                    FREE
                  </td>
                </tr>

              </table>

              <div style="
                height:1px;
                background:#e2e8f0;
                margin:26px 0;
              "></div>

              <table width="100%">

                <tr>

                  <td style="
                    font-size:20px;
                    font-weight:bold;
                  ">
                    TOTAL
                  </td>

                  <td align="right" style="
                    font-size:20px;
                    font-weight:bold;
                  ">
                    ₹ <%= invoice.total %>
                  </td>

                </tr>

              </table>

            </div>

          </td>

        </tr>
      </table>

    </div>
  </div>

</body>

</html>